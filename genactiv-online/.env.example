# Auth
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=$2b$10$... # Generate: node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Klaviyo
KLAVIYO_API_KEY=pk_...

# Shopify
SHOPIFY_ACCESS_TOKEN=shpat_...
MYSHOPIFY_DOMAIN=genactiv.myshopify.com

# Meta Ads
META_ACCESS_TOKEN=...

# Google OAuth (shared by Google Ads and GA4)
GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_REFRESH_TOKEN=1//... # From: cd google-ads-mcp && python generate_refresh_token.py
GOOGLE_ADS_LOGIN_CUSTOMER_ID=2538328866

# GA4
GA4_PROPERTY_ID=279858535
GA4_REFRESH_TOKEN=1//... # From: python generate_ga4_token.py

# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=... # Random string 32+ characters
