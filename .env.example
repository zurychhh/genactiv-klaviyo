# GenActiv Klaviyo — Environment Variables
# Skopiuj do .env i uzupełnij wartości

# Shopify
SHOPIFY_DOMAIN=genactiv.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
SHOPIFY_API_VERSION=2024-01

# Baselinker
BASELINKER_TOKEN=XXXXXXXXXX-XXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google OAuth (GA4 token generator)
GA4_OAUTH_CLIENT_ID=XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GA4_OAUTH_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXX
