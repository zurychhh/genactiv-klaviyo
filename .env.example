# GenActiv Klaviyo — Environment Variables (root)
# Skopiuj do .env i uzupelnij wartosci
# Uzywane przez: skrypty Python + setup-claude.sh (generowanie .mcp.json)
# Dla genactiv-online (web terminal) — osobny .env w genactiv-online/.env.example

# ============================================
# Shopify
# ============================================
SHOPIFY_DOMAIN=genactiv.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
SHOPIFY_API_VERSION=2024-01

# ============================================
# Baselinker
# ============================================
BASELINKER_TOKEN=XXXXXXXXXX-XXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# Klaviyo (MCP server)
# ============================================
KLAVIYO_API_KEY=pk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# Google OAuth (shared by Google Ads + GA4 token generators)
# ============================================
GOOGLE_OAUTH_CLIENT_ID=XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXX
# Aliases used by generate_ga4_token.py:
GA4_OAUTH_CLIENT_ID=${GOOGLE_OAUTH_CLIENT_ID}
GA4_OAUTH_CLIENT_SECRET=${GOOGLE_OAUTH_CLIENT_SECRET}

# ============================================
# Google Ads
# ============================================
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_GOOGLE_ADS_DEVELOPER_TOKEN
GOOGLE_ADS_LOGIN_CUSTOMER_ID=2538328866

# ============================================
# GA4
# ============================================
GA4_PROPERTY_ID=279858535

# ============================================
# Meta Ads
# ============================================
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN

# ============================================
# TikTok Business API (generate_tiktok_token.py)
# ============================================
TIKTOK_APP_ID=7612480542698176529
TIKTOK_SECRET=YOUR_TIKTOK_APP_SECRET
TIKTOK_ACCESS_TOKEN=YOUR_TIKTOK_ACCESS_TOKEN

# ============================================
# Senuto SEO
# ============================================
SENUTO_API_KEY=YOUR_SENUTO_JWT_TOKEN

# ============================================
# Microsoft Clarity (MCP server + heatmap analytics)
# Project ID: 3354986136401458
# ============================================
CLARITY_API_TOKEN=YOUR_CLARITY_JWT_TOKEN

# ============================================
# Teams Webhook (Daily Agent notifications)
# Create via: Teams → channel → Workflows → "Post to a channel when a webhook request is received"
# ============================================
TEAMS_WEBHOOK_URL=
